{
  "name": "avivox-workspace",
  "version": "0.0.0",
  "author": "https://github.com/abhisin98",
  "private": true,
  "type": "module",
  "repository": "https://github.com/abhisin98/avivox-workspace",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build --concurrency 1 --continue",
    "build:packages": "turbo build --filter=@avivox-workspace/*",
    "lint": "turbo lint",
    "lint:packages": "turbo lint --filter=@avivox-workspace/*",
    "lint:all": "eslint .",
    "type-check": "turbo type-check",
    "type-check:packages": "turbo type-check --filter=@avivox-workspace/*",
    "test": "turbo test --concurrency 1 --continue",
    "test:packages": "turbo test --concurrency 1 --continue --filter=@avivox-workspace/*",
    "test:all": "jest",
    "clean": "rimraf -v --glob \"./{apps,packages}/**/{.turbo,.next,build,__generated__}\"",
    "clean:all": "rimraf -v --glob \"./**/{node_modules,.turbo,.next,build,__generated__}\"",
    "start": "turbo start",
    "format": "prettier --write \"**/*.*\" --config .prettierrc.json  --ignore-path .gitignore --ignore-path .prettierignore",
    "prepare": "husky"
  },
  "devDependencies": {
    "@avivox/eslint-config": "workspace:^",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.5",
    "@microsoft/api-extractor": "^7.58.2",
    "@rslib/core": "latest",
    "@swc/core": "latest",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "25.6.0",
    "cross-env": "latest",
    "dotenv": "latest",
    "dotenv-cli": "latest",
    "eslint": "9.39.2",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "turbo": "latest",
    "typescript": "6.0.2"
  }
}
