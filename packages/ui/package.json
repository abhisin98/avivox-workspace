{
  "name": "@avivox-workspace/ui",
  "version": "1.0.1",
  "description": "Shared UI components library for React",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "import": "./build/*.js",
      "require": "./build/*.cjs",
      "types": "./build/*.d.ts"
    }
  },
  "scripts": {
    "build": "rslib build",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "clean": "rm -rf .turbo build"
  },
  "devDependencies": {
    "@avivox-workspace/eslint-config": "workspace:*",
    "@avivox-workspace/typescript-config": "workspace:*",
    "@rsbuild/plugin-react": "^1.4.6",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.2"
  },
  "peerDependencies": {
    "react": ">=19.2",
    "react-dom": ">=19.2"
  }
}
